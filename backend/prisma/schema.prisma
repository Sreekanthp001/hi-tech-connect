datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  WORKER
}

enum TicketType {
  INSTALLATION
  COMPLAINT
}

enum TicketStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SUBMITTED
  NEW_REQUEST
  SURVEY_ASSIGNED
  SURVEY_COMPLETED
  QUOTATION_GENERATED
  QUOTATION_SENT
  WAITING_CUSTOMER_APPROVAL
  APPROVED
  INSTALLATION_ASSIGNED
  WORK_ASSIGNED
  WORK_COMPLETED
  NEW
  SITE_VISIT_ASSIGNED
  SITE_VISIT_COMPLETED
  INSTALLATION_APPROVED
}

enum TicketProgress {
  REQUESTED
  ASSIGNED
  ON_THE_WAY
  IN_PROGRESS
  COMPLETED
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  phone      String?
  password   String
  role       Role
  telegramId String?
  createdAt  DateTime @default(now())

  designation String?
  finance     WorkerFinance?
  advances    WorkerAdvance[]

  assignments       TicketAssignment[]
  notifications     Notification[]
  ticketPhotos      TicketPhoto[]
  stockTransactions StockTransaction[]

  // Lead and Installation Relations
  assignedLeads        Lead[]                   @relation("LeadTechnician")
  seniorInstallations  InstallationAssignment[] @relation("InstallationSrTech")
  supportInstallations InstallationAssignment[] @relation("InstallationSupport")

  planningTickets     Ticket[] @relation("PlanningWorker")
  installationTickets Ticket[] @relation("InstallationWorker")
  supportTickets1    Ticket[] @relation("SupportWorker1")
  supportTickets2    Ticket[] @relation("SupportWorker2")
}

model Ticket {
  id          String       @id @default(uuid())
  title       String
  description String
  type        TicketType
  status      TicketStatus @default(PENDING)
  address     String
  latitude    Float?
  longitude   Float?

  clientName  String
  clientPhone String
  clientEmail String?
  telegramId  String?

  assignments TicketAssignment[]

  pendingNote     String?
  reviewRequested Boolean @default(false)
  review          Review?

  // Payment & Work Completion Details
  totalAmount    Float?
  amountReceived Float?
  paymentStatus  String? // FULL, PARTIAL, PENDING
  paymentMode    String? // CASH, UPI, BANK
  paymentNote    String?
  workSummary    String?

  // Advanced Workflow Fields
  requestType        String? // "New Installation", "Repair / Maintenance"
  alternatePhone     String?
  siteVisitNotes     String?
  
  // Site Survey Details
  numCameras         Int?
  cableLength        Float?
  nvrDvrType         String?
  hardDiskType       String?
  powerSupply        String?
  surveyNotes        String?
  additionalItems    String?

  quotationItems     Json?
  quotationStatus    QuotationStatus? @default(NONE)
  assignedTechnician String?
  assignedTeam       String?

  planningWorkerId     String?
  planningWorker       User?   @relation("PlanningWorker", fields: [planningWorkerId], references: [id])
  installationWorkerId String?
  installationWorker   User?   @relation("InstallationWorker", fields: [installationWorkerId], references: [id])
  quotation            Quotation?
  
  supportWorker1Id     String?
  supportWorker1       User?   @relation("SupportWorker1", fields: [supportWorker1Id], references: [id])
  supportWorker2Id     String?
  supportWorker2       User?   @relation("SupportWorker2", fields: [supportWorker2Id], references: [id])

  beforeImages       Json?
  afterImages        Json?

  // Upgrade Phases
  ticketProgress     TicketProgress? @default(REQUESTED)
  warrantyStartDate  DateTime?
  warrantyExpiryDate DateTime?
  amcEnabled         Boolean         @default(false)
  amcRenewalDate     DateTime?

  invoice               Invoice?
  ticketPhotos          TicketPhoto[]
  payments              PaymentHistory[]
  internalNotifications InternalNotification[]
  stockTransactions     StockTransaction[]
  items                 TicketItem[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model TicketAssignment {
  id         String   @id @default(uuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id])
  workerId   String
  worker     User     @relation(fields: [workerId], references: [id])
  isPrimary  Boolean  @default(false)
  assignedAt DateTime @default(now())

  @@unique([ticketId, workerId])
}

model Invoice {
  id             String   @id @default(uuid())
  invoiceNumber  String   @unique // format: HTC-YYYY-0001
  ticketId       String   @unique
  ticket         Ticket   @relation(fields: [ticketId], references: [id])
  customerName   String
  customerPhone  String
  totalAmount    Float
  amountReceived Float
  balance        Float
  gstNumber      String?
  companyAddress String?
  paymentStatus  String
  createdAt      DateTime @default(now())
}

model TicketPhoto {
  id         String   @id @default(uuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id])
  workerId   String?
  worker     User?    @relation(fields: [workerId], references: [id])
  type       String // BEFORE, AFTER
  imageUrl   String
  uploadedBy String
  createdAt  DateTime @default(now())
}

model Expense {
  id        String   @id @default(uuid())
  title     String
  amount    Float
  category  String // SALARY, MATERIAL, OFFICE, OTHER
  date      DateTime @default(now())
  notes     String?
  createdBy String?
  createdAt DateTime @default(now())
}

model PaymentHistory {
  id          String   @id @default(uuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id])
  amount      Float
  paymentMode String // CASH, UPI, BANK
  addedBy     Role // ADMIN, WORKER
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String
  ticketId  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(uuid())
  ticketId  String   @unique
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}

model WorkPhoto {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String
  createdAt DateTime @default(now())
}

model InternalNotification {
  id         String   @id @default(uuid())
  type       String // PAYMENT, WARRANTY, AMC, OTHER
  message    String
  ticketId   String?
  customerId String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  // Optional: Relations if needed
  ticket Ticket? @relation(fields: [ticketId], references: [id])

  @@index([isRead])
  @@index([createdAt])
}

model WorkerFinance {
  id           String   @id @default(uuid())
  workerId     String   @unique
  worker       User     @relation(fields: [workerId], references: [id])
  baseSalary   Float?
  totalEarned  Float    @default(0)
  totalAdvance Float    @default(0)
  updatedAt    DateTime @updatedAt
}

model WorkerAdvance {
  id        String   @id @default(uuid())
  workerId  String
  worker    User     @relation(fields: [workerId], references: [id])
  amount    Float
  reason    String?
  createdAt DateTime @default(now())
}

model ProductMaster {
  id                String   @id @default(uuid())
  name              String
  category          String
  brand             String?
  type              String?
  purchasePrice     Float?
  sellingPrice      Float
  unitType          String // piece, meter, per_camera
  gstPercent        Float    @default(18)
  minimumStockAlert Int      @default(5)
  isActive          Boolean  @default(true)
  currentStock      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  items        QuotationItem[]
  transactions StockTransaction[]
  ticketItems  TicketItem[]
    ticketMaterials TicketMaterial[]
}


enum TransactionType {
  IN
  OUT
  ADJUSTMENT
}

enum ReferenceType {
  PURCHASE
  WORKER_ISSUE
  RETURN
  MANUAL_ADJUSTMENT
  TICKET_USAGE
  RETURN_FROM_TICKET
}

model StockTransaction {
  id              String          @id @default(uuid())
  productId       String
  product         ProductMaster   @relation(fields: [productId], references: [id])
  transactionType TransactionType
  quantity        Float
  referenceType   ReferenceType
  workerId        String?
  worker          User?           @relation(fields: [workerId], references: [id])
  customerId      String? // Optional customer reference
  ticketId        String?
  ticket          Ticket?         @relation(fields: [ticketId], references: [id])
  createdByAdmin  Boolean         @default(true)
  notes           String?
  createdAt       DateTime        @default(now())
}

enum QuotationStatus {
  NONE
  PENDING
  SENT
  APPROVED
  REJECTED
  CANCELLED
}

model Quotation {
  id          String @id @default(uuid())
  quotationNo String @unique // e.g., QTN-2024-001

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  ticketId String? @unique
  ticket   Ticket? @relation(fields: [ticketId], references: [id])

  customerName  String
  customerPhone String
  cameraCount   Int
  cameraType    String
  wireLength    Float
  notes         String?
  subtotal      Float
  discount      Float           @default(0)
  discountType  String? // FLAT, PERCENTAGE
  gstAmount     Float
  grandTotal    Float
  status        QuotationStatus @default(NONE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  items QuotationItem[]
}

model QuotationItem {
  id          String         @id @default(uuid())
  quotationId String
  quotation   Quotation      @relation(fields: [quotationId], references: [id])
  productId   String?
  product     ProductMaster? @relation(fields: [productId], references: [id])
  name        String
  quantity    Int
  unitPrice   Float // Stored separately for historical accuracy
  totalPrice  Float
  createdAt   DateTime       @default(now())
}

enum LeadStatus {
  NEW_LEAD
  SITE_VISIT_PENDING
  SITE_VISITED
  QUOTATION_PREPARED
  QUOTATION_SENT
  FOLLOW_UP_PENDING
  APPROVED
  TEAM_ASSIGNED
  INSTALLATION_IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Lead {
  id                 String     @id @default(uuid())
  customerName       String
  phone              String
  address            String?
  requirementSummary String?
  status             LeadStatus @default(NEW_LEAD)

  assignedTechnicianId String?
  assignedTechnician   User?   @relation("LeadTechnician", fields: [assignedTechnicianId], references: [id])

  siteVisitDate    DateTime?
  nextFollowUpDate DateTime?
  followUpCount    Int       @default(0)
  lastFollowUpNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotations             Quotation[]
  installationAssignment InstallationAssignment?
}

enum InstallationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model InstallationAssignment {
  id String @id @default(uuid())

  leadId String @unique
  lead   Lead   @relation(fields: [leadId], references: [id])

  srTechnicianId String
  srTechnician   User   @relation("InstallationSrTech", fields: [srTechnicianId], references: [id])

  supportStaffId String?
  supportStaff   User?   @relation("InstallationSupport", fields: [supportStaffId], references: [id])

  assignedDate DateTime           @default(now())
  status       InstallationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketItem {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  productId String?
  product   ProductMaster? @relation(fields: [productId], references: [id])
  itemName  String
  quantity  Int      @default(1)
  price     Float    @default(0)
  createdAt DateTime @default(now())
}

model TicketMaterial {
    id        String   @id @default(uuid())
    ticketId  String
    productId String
    quantity  Int
    type      String   @default("USED")
    notes     String?
    createdAt DateTime @default(now())
    product   ProductMaster @relation(fields: [productId], references: [id])
}
