datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  WORKER
}

enum TicketType {
  INSTALLATION
  COMPLAINT
}

enum TicketStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TicketProgress {
  REQUESTED
  ASSIGNED
  ON_THE_WAY
  IN_PROGRESS
  COMPLETED
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  phone      String?
  password   String
  role       Role
  telegramId String?
  createdAt  DateTime @default(now())

  ticketsAssigned Ticket[]
  notifications   Notification[]
}

model Ticket {
  id          String       @id @default(uuid())
  title       String
  description String
  type        TicketType
  status      TicketStatus @default(PENDING)
  address     String
  latitude    Float?
  longitude   Float?

  clientName  String
  clientPhone String
  clientEmail String?

  workerId String?
  worker   User?   @relation(fields: [workerId], references: [id])

  pendingNote     String?
  reviewRequested Boolean @default(false)
  review          Review?

  // Payment & Work Completion Details
  totalAmount    Float?
  amountReceived Float?
  paymentStatus  String? // FULL, PARTIAL, PENDING
  paymentMode    String? // CASH, UPI, BANK
  paymentNote    String?
  workSummary    String?

  // Upgrade Phases
  ticketProgress     TicketProgress? @default(REQUESTED)
  warrantyStartDate  DateTime?
  warrantyExpiryDate DateTime?
  amcEnabled         Boolean         @default(false)
  amcRenewalDate     DateTime?

  invoice               Invoice?
  ticketPhotos          TicketPhoto[]
  payments              PaymentHistory[]
  internalNotifications InternalNotification[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model Invoice {
  id             String   @id @default(uuid())
  invoiceNumber  String   @unique // format: HTC-YYYY-0001
  ticketId       String   @unique
  ticket         Ticket   @relation(fields: [ticketId], references: [id])
  customerName   String
  customerPhone  String
  totalAmount    Float
  amountReceived Float
  balance        Float
  gstNumber      String?
  companyAddress String?
  paymentStatus  String
  createdAt      DateTime @default(now())
}

model TicketPhoto {
  id         String   @id @default(uuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id])
  type       String // BEFORE, AFTER
  imageUrl   String
  uploadedBy String
  createdAt  DateTime @default(now())
}

model Expense {
  id        String   @id @default(uuid())
  title     String
  amount    Float
  category  String // SALARY, MATERIAL, OFFICE, OTHER
  date      DateTime @default(now())
  notes     String?
  createdBy String?
  createdAt DateTime @default(now())
}

model PaymentHistory {
  id          String   @id @default(uuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id])
  amount      Float
  paymentMode String // CASH, UPI, BANK
  addedBy     Role // ADMIN, WORKER
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(uuid())
  ticketId  String   @unique
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}

model WorkPhoto {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String
  createdAt DateTime @default(now())
}

model InternalNotification {
  id         String   @id @default(uuid())
  type       String // PAYMENT, WARRANTY, AMC, OTHER
  message    String
  ticketId   String?
  customerId String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  // Optional: Relations if needed
  ticket Ticket? @relation(fields: [ticketId], references: [id])

  @@index([isRead])
  @@index([createdAt])
}
