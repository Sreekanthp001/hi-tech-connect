datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  WORKER
}

enum TicketType {
  INSTALLATION
  COMPLAINT
}

enum TicketStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  ticketsAssigned Ticket[]
}

model Ticket {
  id          String       @id @default(uuid())
  title       String
  description String
  type        TicketType
  status      TicketStatus @default(PENDING)
  address     String
  latitude    Float?
  longitude   Float?

  clientName  String
  clientPhone String
  clientEmail String?

  workerId String?
  worker   User?   @relation(fields: [workerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
